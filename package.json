{
  "name": "netop",
  "private": true,
  "workspaces": [
    "projects/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "yarn workspace @netop/webapp dev",
    "build": "yarn workspaces run build",
    "preview": "yarn workspace @netop/webapp preview",
    "typecheck": "yarn workspaces run typecheck",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.45.0",
    "oxlint": "~1.60.0",
    "typescript": "~6.0.0"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,vue}": "oxfmt --write"
  },
  "packageManager": "yarn@1.22.22"
}
