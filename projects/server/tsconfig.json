{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["bun-types"],
    "paths": {
      "@/*": ["./src/*"],
      "@app/*": ["./src/app/*"],
      "@simulation/*": ["./src/app/simulation/*"],
      "@commands/*": ["./src/app/commands/*"],
      "@netop/types": ["../types/src/index.ts"]
    }
  },
  "include": ["src"]
}
